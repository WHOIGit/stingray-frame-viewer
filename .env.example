# Manifest store (amplify-db-utils). Local filesystem path or s3://... URL.
STINGRAY_STORE_ROOT=./.dev-store

# S3 credentials for the manifest store (only if STORE_ROOT is on S3)
# STINGRAY_STORE_S3_ENDPOINT=
# STINGRAY_STORE_S3_ACCESS_KEY=
# STINGRAY_STORE_S3_SECRET_KEY=

# Phase 2 cache toggle. Set to true to read/write encoded frames in VAST S3.
STINGRAY_CACHE_ENABLED=false

# VAST S3 cache (required when STINGRAY_CACHE_ENABLED=true)
# STINGRAY_CACHE_BUCKET=
# STINGRAY_CACHE_S3_ENDPOINT=
# STINGRAY_CACHE_S3_ACCESS_KEY=
# STINGRAY_CACHE_S3_SECRET_KEY=

# Frame encoding defaults
STINGRAY_DEFAULT_FORMAT=png
STINGRAY_JPEG_QUALITY=90

# Neighbors endpoint window (comma-separated offsets)
STINGRAY_NEIGHBOR_WINDOW=1,5

# ---------------------------------------------------------------------------
# Docker Compose deployment only — host-path substitution.
#
# Everything above is service config read by the app (pydantic-settings).
# The two vars below are different: docker compose reads them on the *host*
# to fill in the volume mounts in compose.yml. They are NOT consumed by the
# service process (the app ignores them — `extra="ignore"`).
#
# Host path to the Stingray data root (the AVIs). Mounted read-only into the
# container at /proj/nes-lter/Stingray/data, which is what the manifest's
# media_path values expect. Required by compose.
# STINGRAY_AVI_HOST_DIR=/mnt/my/mount/point
#
# Host path for the manifest store. Mounted read-write at /var/stingray/manifest.
# Must be writable by the container UID (1000) and persistent. Defaults to
# ./manifest (relative to compose.yml) if unset.
# STINGRAY_MANIFEST_HOST_DIR=/var/lib/stingray/manifest
