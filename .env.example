# Manifest store (amplify-db-utils). Local filesystem path or s3://... URL.
STINGRAY_STORE_ROOT=./.dev-store

# S3 credentials for the manifest store (only if STORE_ROOT is on S3)
# STINGRAY_STORE_S3_ENDPOINT=
# STINGRAY_STORE_S3_ACCESS_KEY=
# STINGRAY_STORE_S3_SECRET_KEY=

# Phase 2 cache toggle. Set to true to read/write encoded frames in VAST S3.
STINGRAY_CACHE_ENABLED=false

# VAST S3 cache (required when STINGRAY_CACHE_ENABLED=true)
# STINGRAY_CACHE_BUCKET=
# STINGRAY_CACHE_S3_ENDPOINT=
# STINGRAY_CACHE_S3_ACCESS_KEY=
# STINGRAY_CACHE_S3_SECRET_KEY=

# Frame encoding defaults
STINGRAY_DEFAULT_FORMAT=png
STINGRAY_JPEG_QUALITY=90

# Neighbors endpoint window (comma-separated offsets)
STINGRAY_NEIGHBOR_WINDOW=1,5
